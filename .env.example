# --- VERCEL DEPLOYMENT ---
# 1. Go to Vercel Project Settings > Environment Variables
# 2. Add GEMINI_API_KEY with your key from https://aistudio.google.com/app/apikey
# 3. Add APP_URL (optional, defaults to your vercel app url)
# 
# Vercel will automatically run 'npm run build' and serve the 'dist' folder.
# The backend logic is handled as serverless functions in the /api folder.

GEMINI_API_KEY="your_api_key_here"
APP_URL="https://your-app.vercel.app"
